# Copy to .env at the repo root. Both apps read from here in dev.

# PostgreSQL (docker-compose exposes 5432; tools/dev-db embedded postgres uses 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/trademind

# API
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# Better Auth (generate a long random secret: `openssl rand -base64 32`)
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:4000

# Google OAuth (optional — social login is disabled when unset)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web (Next.js needs the NEXT_PUBLIC_ prefix at build time)
NEXT_PUBLIC_API_URL=http://localhost:4000
